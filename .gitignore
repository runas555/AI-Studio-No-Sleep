# ============================================================================
# GIT IGNORE CONFIGURATION: Keeps the GitHub repository clean and lightweight.
# ============================================================================

# Node.js dependencies & logs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS system files (macOS & Windows)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
System Volume Information/
$RECYCLE.BIN/
*.sys

# Exclude all CJS patch/automation scripts from GitHub commits
*.cjs

# Exclude temporary text dumps and documentation drafts
*.txt
dump.txt

# Build folders (if any are generated in the future)
dist/
build/
.cache/