{
    "manifest_version": 3,
    "name": "AI Studio No Sleep",
    "version": "2.0.0",
    "description": "Prevents Google AI Studio from pausing text generation in background tabs.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "tabs",
        "power",
        "notifications",
        "alarms"
    ],
    "host_permissions": [
        "https://aistudio.google.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://aistudio.google.com/*"
            ],
            "js": [
                "inject.js"
            ],
            "run_at": "document_start",
            "all_frames": true,
            "world": "MAIN"
        },
        {
            "matches": [
                "https://aistudio.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}